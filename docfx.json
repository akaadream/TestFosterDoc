{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "bin/**.dll"
          ],
          "src": "./"
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}",
          "api/*.yml"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "templates/singulinkfx"
    ],
    "globalMetadata": {
      "_appName": "",
      "_appTitle": "Foster",
      "_appLogoPath": "images/Foster.png",
      "_appFaviconPath": "images/Icon.png",
      "_enableSearch": true,
      "pdf": false
    }
  }
}